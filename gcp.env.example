# Copy to gcp.env (gitignored): cp gcp.env.example gcp.env
# Makefile loads gcp.env when present via -include.

GCP_PROJECT=your-gcp-project-id
GCP_REGION=us-central1
AR_REPO=ml-repo
GCP_CLUSTER=tao-cluster

# Optional: full image path (default: $(GCP_REGION)-docker.pkg.dev/$(GCP_PROJECT)/$(AR_REPO)/ml-workload)
# AR_IMAGE=us-central1-docker.pkg.dev/your-gcp-project-id/ml-repo/ml-workload
